[node name="HelpLabel" type="Label" parent="RenderBridge/UILayer/HUD/HelpPanel"]
layout_mode = 2
theme_override_colors/font_color = Color(0.9, 0.95, 1.0, 1)
theme_override_font_sizes/font_size = 13
text = "CONTROLS
─────────────────
LClick      Select / Designate
RClick      Set waypoint
Shift+RClick  Add waypoint
F           Fire weapon
C           Cycle weapon
L           Launch helicopter
W / X       Speed +/- 5kts
[ / ]       Depth (subs only)
SPACE       Pause / Resume
1-5         Time scale
R           Toggle radar
S           Toggle sonar
Tab         Cycle units
H           Center camera
Scroll      Zoom in/out
Mid-Drag    Pan map
ESC         Return to menu"
